#!/usr/bin/env bash
# csm — Claude Session Manager
# https://github.com/rza-byte/csm

set -euo pipefail

# ── Paths ─────────────────────────────────────────────────────────────────────
CSM_SESSION="csm"
CSM_LIB_DIR="${CSM_LIB_DIR:-$HOME/.local/share/csm/lib}"
CSM_STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/csm"
CSM_AUDIT_LOG="$CSM_STATE_DIR/audit.log"
CLAUDE_SESSIONS="$HOME/.claude/sessions"

# ── Colors ────────────────────────────────────────────────────────────────────
RED=$'\033[0;31m';  YELLOW=$'\033[0;33m'; GREEN=$'\033[0;32m'
GREY=$'\033[0;90m'; BOLD=$'\033[1m';      RESET=$'\033[0m'
CYAN=$'\033[0;36m'

# ── Helpers ───────────────────────────────────────────────────────────────────

_log_audit() {
    mkdir -p "$CSM_STATE_DIR"
    echo "$(date -Iseconds) $*" >> "$CSM_AUDIT_LOG"
}

_ensure_state_dir() {
    mkdir -p "$CSM_STATE_DIR"
}

# Returns TSV: pid\talive\tstatus\tcwd\tproject\tage_min
_get_sessions() {
    python3 "$CSM_LIB_DIR/csm-status.py" sessions 2>/dev/null || true
}

# Graceful kill: SIGTERM, wait up to 10s, then SIGKILL
_safe_kill_claude() {
    local pid="$1"
    [[ -d "/proc/$pid" ]] || return 0
    kill -TERM "$pid" 2>/dev/null || true
    local n=0
    while [[ -d "/proc/$pid" ]] && (( n < 10 )); do
        sleep 1; (( n++ ))
    done
    [[ -d "/proc/$pid" ]] && kill -KILL "$pid" 2>/dev/null || true
}

# Get Claude child PID from a tmux window's shell PID
_window_claude_pid() {
    local win="$1"
    local pane_pid
    pane_pid=$(tmux display-message -t "${CSM_SESSION}:${win}" -p '#{pane_pid}' 2>/dev/null) || return 1
    pgrep -P "$pane_pid" -f "claude" 2>/dev/null | head -1 || \
    pgrep -P "$pane_pid" 2>/dev/null | head -1 || true
}

# ── Dashboard ─────────────────────────────────────────────────────────────────

# Populated by _render_dashboard; used by key handlers.
# Format per entry: "idx|pid|alive|status|cwd|project|tmux_win"
_SESSION_LIST=()
_cursor=1       # 1-based index of highlighted row (k9s-style navigation)

_sep() { printf ' '; printf '%0.s─' {1..70}; echo; }

_render_dashboard() {
    local data; data=$(_get_sessions)
    _SESSION_LIST=()

    # Precompute managed windows once (cwd -> window_index)
    declare -A _mgd=()
    while IFS=' ' read -r widx ppath; do
        [[ -n "$ppath" ]] && _mgd["$ppath"]="$widx"
    done < <(tmux list-windows -t "$CSM_SESSION" \
        -F '#{window_index} #{pane_current_path}' 2>/dev/null)

    local live=0 dead=0 orphans=0

    # ── Header ───────────────────────────────────────────────────────────────
    printf '\033[H\033[2J'

    printf " ${BOLD}${CYAN}CSM${RESET} ${BOLD}Claude Session Manager${RESET}"

    while IFS=$'\t' read -r _ alive _ _ _ _; do
        [[ "$alive" == "True" ]] && (( live++ )) || (( dead++ )) || true
    done <<< "$data"

    printf "   ${GREY}${live} live"
    (( dead > 0 )) && printf " · ${dead} dead" || true
    printf "   $(date '+%H:%M:%S')${RESET}\n"
    _sep

    printf " ${BOLD}%-4s %-9s  %-26s  %-6s  %s${RESET}\n" \
        "#" "STATUS" "PROJECT" "AGE" "DIRECTORY"
    _sep

    # ── Session rows ─────────────────────────────────────────────────────────
    if [[ -z "$data" ]]; then
        printf "\n ${GREY}No Claude sessions found. Press N to start one.${RESET}\n\n"
    else
        local idx=1
        while IFS=$'\t' read -r pid alive st cwd project age_min; do
            local icon color tmux_win="" tag=""
            if [[ "$alive" != "True" ]]; then
                icon="💀"; color="$GREY"; st="dead"
            else
                case "$st" in
                    busy)    icon="●"; color="$RED"    ;;
                    waiting) icon="⏳"; color="$YELLOW" ;;
                    idle)    icon="○"; color="$GREEN"  ;;
                    *)       icon="?"; color="$GREY"   ;;
                esac
            fi

            tmux_win="${_mgd[$cwd]:-}"
            if [[ -n "$tmux_win" ]]; then
                tag=" ${GREY}[win ${tmux_win}]${RESET}"
            else
                (( orphans++ )) || true
            fi

            # Cursor indicator (k9s-style ▶)
            local sel_pre="" sel_idx_color="$BOLD"
            if [[ "$idx" == "$_cursor" ]]; then
                sel_pre="${CYAN}▶${RESET}"
                sel_idx_color="${BOLD}${CYAN}"
            else
                sel_pre=" "
            fi

            local short_cwd="${cwd/#$HOME/\~}"
            printf " %b${sel_idx_color}%2d${RESET}  ${color}%s %-8s${RESET}  %-26s  ${GREY}%-6s${RESET}  %-36s%b\n" \
                "$sel_pre" "$idx" "$icon" "$st" "${project:0:25}" "${age_min}m" \
                "${short_cwd:0:36}" "$tag"

            _SESSION_LIST+=("${idx}|${pid}|${alive}|${st}|${cwd}|${project}|${tmux_win}")
            (( idx++ )) || true
        done <<< "$data"

        # Clamp cursor to valid range after data refresh
        local total=$(( idx - 1 ))
        (( _cursor < 1 )) && _cursor=1 || true
        (( _cursor > total && total > 0 )) && _cursor=$total || true
    fi

    # ── Footer ───────────────────────────────────────────────────────────────
    _sep
    if (( orphans > 0 )); then
        printf " ${YELLOW}⚠  %d orphan session(s) not in CSM — press A to adopt${RESET}\n" "$orphans"
        _sep
    fi
    printf " ${CYAN}j/k↑↓${RESET} nav  ${CYAN}Enter${RESET} switch  ${CYAN}[N]${RESET} new  ${CYAN}[/]${RESET} search  ${CYAN}[K]${RESET} kill  ${CYAN}[A]${RESET} adopt  ${CYAN}[Q]${RESET} quit\n"
}

# Dashboard loop — alternate screen prevents scroll corruption; 2s debounce on inotify
_dashboard_loop() {
    local inotify_pipe="" inotify_pid="" last_render=0

    # Alternate screen: scroll shows this buffer only, never terminal history
    tput smcup 2>/dev/null || printf '\033[?1049h'
    printf '\033[?25l'   # hide cursor
    printf '\033[2J\033[H'

    if command -v inotifywait &>/dev/null; then
        inotify_pipe=$(mktemp -u /tmp/csm-inotify-XXXXXX).pipe
        mkfifo "$inotify_pipe" 2>/dev/null || inotify_pipe=""
        if [[ -n "$inotify_pipe" ]]; then
            inotifywait -m "$CLAUDE_SESSIONS" -e modify,create,delete \
                --format '%e' -q > "$inotify_pipe" 2>/dev/null &
            inotify_pid=$!
        fi
    fi

    _cleanup_dashboard() {
        [[ -n "$inotify_pid" ]] && kill "$inotify_pid" 2>/dev/null || true
        [[ -n "$inotify_pipe" ]] && rm -f "$inotify_pipe" || true
        printf '\033[?25h'
        tput rmcup 2>/dev/null || printf '\033[?1049l'
    }
    trap '_cleanup_dashboard' EXIT INT TERM

    while true; do
        local now; now=$(date +%s)
        if (( now - last_render >= 2 )); then
            _render_dashboard
            last_render=$now
        fi

        local key=""
        if read -rs -n1 -t1 key 2>/dev/null; then
            # Parse ESC sequences — arrow keys move the cursor
            if [[ "$key" == $'\033' ]]; then
                local seq=""
                read -rs -n2 -t0.1 seq 2>/dev/null || true
                case "$seq" in
                    "[A")  # up arrow
                        (( _cursor > 1 )) && (( _cursor-- )) || true
                        last_render=0 ;;
                    "[B")  # down arrow
                        local max="${#_SESSION_LIST[@]}"
                        (( _cursor < max )) && (( _cursor++ )) || true
                        last_render=0 ;;
                    *) ;;  # discard other sequences (mouse, F-keys, etc.)
                esac
                continue
            fi
            case "$key" in
                j)  # cursor down
                    local max="${#_SESSION_LIST[@]}"
                    (( _cursor < max )) && (( _cursor++ )) || true
                    last_render=0 ;;
                k)  # cursor up
                    (( _cursor > 1 )) && (( _cursor-- )) || true
                    last_render=0 ;;
                $'\r'|$'\n')  # Enter — switch to selected row
                    _select_entry ;;
                [1-9]) _switch_or_hint "$key" ;;
                n|N)
                    printf '\033[?25h'
                    _new_popup
                    printf '\033[?25l'
                    last_render=0
                    ;;
                /)
                    printf '\033[?25h'
                    _search_prompt
                    printf '\033[?25l'
                    last_render=0
                    ;;
                J)
                    printf '\033[?25h'
                    _search_prompt
                    printf '\033[?25l'
                    last_render=0
                    ;;
                K)
                    printf '\033[?25h'
                    _kill_prompt
                    printf '\033[?25l'
                    last_render=0
                    ;;
                l|L)
                    printf '\033[?25h'
                    _log_prompt
                    printf '\033[?25l'
                    ;;
                a|A)
                    printf '\033[?25h\033[2J\033[H'
                    cmd_adopt
                    read -rs -n1 -p $'\nPress any key to return...' 2>/dev/null || true
                    printf '\033[?25l\033[2J\033[H'
                    last_render=0
                    ;;
                r|R) last_render=0 ;;
                q|Q)
                    _cleanup_dashboard
                    trap - EXIT INT TERM
                    tmux detach-client 2>/dev/null || true
                    return
                    ;;
            esac
        fi

        # Inotify: drain all pending events, then force redraw after debounce
        if [[ -n "$inotify_pipe" ]] && [[ -p "$inotify_pipe" ]]; then
            local got_event=false
            while read -t0.05 _ < "$inotify_pipe" 2>/dev/null; do got_event=true; done
            # Only mark for redraw if 2s have passed (debounce rapid writes)
            if [[ "$got_event" == true ]]; then
                local n; n=$(date +%s)
                (( n - last_render >= 2 )) && last_render=0 || true
            fi
        fi
    done
}

# Switch to a tmux window, or show a hint if session is an orphan
_switch_or_hint() {
    local key="$1"
    local entry="${_SESSION_LIST[$((key - 1))]:-}"
    [[ -z "$entry" ]] && return

    IFS='|' read -r idx _ _ _ _ project tmux_win <<< "$entry"

    if [[ -n "$tmux_win" ]]; then
        tmux select-window -t "${CSM_SESSION}:${tmux_win}" 2>/dev/null || true
    else
        # Print hint on last line without disrupting the table
        local rows; rows=$(tput lines 2>/dev/null || echo 24)
        printf '\033[%d;1H\033[2K' "$rows"
        printf " ${YELLOW}#%d %s is an orphan — press A to adopt into CSM${RESET}" \
            "$idx" "$project"
        sleep 2
        printf '\033[%d;1H\033[2K' "$rows"
    fi
}

_new_popup() {
    if [[ -n "${TMUX:-}" ]]; then
        local dirs=()
        mapfile -t dirs < <(python3 "$CSM_LIB_DIR/csm-status.py" recent-dirs 2>/dev/null | head -9)
        local -a menu_args=("-T" " New Claude Session")
        local cur_dir="$PWD"
        menu_args+=("$(basename "$cur_dir")  (current dir)" "0" "run-shell 'csm new \"$cur_dir\"'")
        local i=1
        for dir in "${dirs[@]}"; do
            [[ -d "$dir" ]] || continue
            [[ "$dir" == "$cur_dir" ]] && continue
            menu_args+=("$(basename "$dir")" "$i" "run-shell 'csm new \"$dir\"'")
            (( i++ )) || true
        done
        menu_args+=("-" "" "")
        menu_args+=("Enter path..." "e" "command-prompt -p 'Directory:' 'run-shell \"csm new \\\"%%\\\"\"'")
        tmux display-menu "${menu_args[@]}" 2>/dev/null || true
    else
        printf "\n  Directory (Enter for current): "
        local dir; read -re dir
        [[ -z "$dir" ]] && dir="$PWD"
        cmd_new "$dir"
        read -rs -n1 -p $'\n  Press any key...\n' 2>/dev/null || true
    fi
}

# Switch to the currently cursor-highlighted session
_select_entry() {
    local entry="${_SESSION_LIST[$((_cursor - 1))]:-}"
    [[ -z "$entry" ]] && return
    IFS='|' read -r idx _ _ _ _ project tmux_win <<< "$entry"
    if [[ -n "$tmux_win" ]]; then
        tmux select-window -t "${CSM_SESSION}:${tmux_win}" 2>/dev/null || true
    else
        _switch_or_hint "$idx"
    fi
}

# Search sessions by name (/), move cursor to match and optionally switch
_search_prompt() {
    printf '\033[?25h'
    printf "\n  Search (name or #): "
    local query; read -r query
    [[ -z "$query" ]] && return

    local found_idx=0
    for entry in "${_SESSION_LIST[@]}"; do
        IFS='|' read -r idx _ _ _ _ project tmux_win <<< "$entry"
        if [[ "$query" == "$idx" ]] || [[ "${project,,}" == *"${query,,}"* ]]; then
            found_idx="$idx"
            break
        fi
    done

    if [[ "$found_idx" == "0" ]]; then
        printf "  ${RED}No session matching '%s'${RESET}\n" "$query"
        sleep 1.5
    else
        _cursor="$found_idx"
        # Auto-switch if there's a tmux window; otherwise show orphan hint
        local entry="${_SESSION_LIST[$((_cursor - 1))]:-}"
        IFS='|' read -r _ _ _ _ _ project tmux_win <<< "$entry"
        if [[ -n "$tmux_win" ]]; then
            tmux select-window -t "${CSM_SESSION}:${tmux_win}" 2>/dev/null || true
        else
            printf "  ${YELLOW}%s is an orphan — press A to adopt into CSM${RESET}\n" "$project"
            sleep 2
        fi
    fi
}

# Legacy alias (cmd_jump still works as external subcommand)
_jump_prompt() { _search_prompt; }

_kill_prompt() {
    printf "\n  Kill session # (from list): "
    local idx; read -r idx
    [[ "$idx" =~ ^[0-9]+$ ]] || return

    local entry="${_SESSION_LIST[$((idx - 1))]:-}"
    if [[ -z "$entry" ]]; then
        printf "  ${RED}No session #%s${RESET}\n" "$idx"; sleep 1; return
    fi

    IFS='|' read -r _ pid _ _ cwd project tmux_win <<< "$entry"

    if [[ -n "$tmux_win" ]]; then
        cmd_kill "$tmux_win"
    else
        # Orphan: kill the process directly
        printf "  Kill orphan '%s' (PID %s)? [y/N]: " "$project" "$pid"
        local ans; read -r ans
        if [[ "$ans" =~ ^[Yy]$ ]]; then
            _safe_kill_claude "$pid"
            printf "  Killed.\n"
        fi
    fi
    read -rs -n1 -p $'  Press any key...\n' 2>/dev/null || true
}

_log_prompt() {
    printf "\n  Log for session # (from list): "
    local idx; read -r idx
    [[ "$idx" =~ ^[0-9]+$ ]] || return

    local entry="${_SESSION_LIST[$((idx - 1))]:-}"
    if [[ -z "$entry" ]]; then
        printf "  ${RED}No session #%s${RESET}\n" "$idx"; sleep 1; return
    fi

    IFS='|' read -r _ _ _ _ _ _ tmux_win <<< "$entry"
    local win_arg="${tmux_win:-$idx}"

    tmux display-popup -E -w 90% -h 85% \
        "bash -c 'python3 \"$CSM_LIB_DIR/csm-status.py\" log \"$win_arg\"; echo; read -rs -n1 -p \"Press any key...\"'" \
        2>/dev/null || cmd_log "$win_arg"
}

# ── Subcommands ───────────────────────────────────────────────────────────────

cmd_attach() {
    _ensure_state_dir

    if tmux has-session -t "$CSM_SESSION" 2>/dev/null; then
        if [[ -n "${TMUX:-}" ]]; then
            tmux switch-client -t "$CSM_SESSION"
        else
            tmux attach-session -t "$CSM_SESSION"
        fi
        return
    fi

    # New session — first window is the dashboard (index depends on tmux base-index)
    tmux new-session -d -s "$CSM_SESSION" -n '[dashboard]'
    tmux set-option -t "$CSM_SESSION" status off
    tmux set-option -t "$CSM_SESSION" history-limit 50000
    tmux set-option -t "$CSM_SESSION" mouse off
    tmux set-option -t "$CSM_SESSION" allow-rename off
    tmux set-option -t "$CSM_SESSION" automatic-rename off
    tmux set-option -t "$CSM_SESSION" pane-border-status off

    tmux send-keys -t "${CSM_SESSION}:[dashboard]" 'csm _dashboard' Enter

    _log_audit "attach" "created new csm session"

    if [[ -n "${TMUX:-}" ]]; then
        tmux switch-client -t "$CSM_SESSION"
    else
        tmux attach-session -t "$CSM_SESSION"
    fi
}

cmd_new() {
    local target_dir="${1:-}"

    if [[ -z "$target_dir" ]]; then
        if [[ -n "${TMUX:-}" ]]; then
            _new_popup
            return
        else
            printf "Directory (Enter for current dir): "
            read -re target_dir
            [[ -z "$target_dir" ]] && target_dir="$PWD"
        fi
    fi

    target_dir="${target_dir/#\~/$HOME}"
    target_dir=$(realpath "$target_dir" 2>/dev/null || echo "$target_dir")

    if [[ ! -d "$target_dir" ]]; then
        echo "Error: not a directory: $target_dir" >&2; return 1
    fi

    local project
    project=$(basename "$target_dir")

    # Read per-project .csmrc (walk up from target_dir)
    local kube_ctx="" aws_prof=""
    local rc_file=""
    local search_dir="$target_dir"
    while [[ "$search_dir" != "/" ]]; do
        if [[ -f "$search_dir/.csmrc" ]]; then
            rc_file="$search_dir/.csmrc"
            break
        fi
        search_dir=$(dirname "$search_dir")
    done
    if [[ -n "$rc_file" ]]; then
        kube_ctx=$(grep -E '^kube_context=' "$rc_file" 2>/dev/null | cut -d= -f2 | tr -d '"' || true)
        aws_prof=$(grep -E '^aws_profile='   "$rc_file" 2>/dev/null | cut -d= -f2 | tr -d '"' || true)
    fi

    # Build shell command: cd, optionally set context, then launch claude
    local launch_cmd="cd '$target_dir'"
    [[ -n "$kube_ctx" ]] && launch_cmd+="; kubectl config use-context '$kube_ctx' 2>/dev/null && echo '  k8s: $kube_ctx'"
    [[ -n "$aws_prof" ]] && launch_cmd+="; export AWS_PROFILE='$aws_prof' && echo '  aws: $aws_prof'"
    launch_cmd+="; exec claude"

    # Ensure csm tmux session exists
    if ! tmux has-session -t "$CSM_SESSION" 2>/dev/null; then
        echo "CSM session not running. Starting it first..."
        cmd_attach &
        sleep 0.5
    fi

    tmux new-window -t "$CSM_SESSION" -n "○ ${project}" "zsh -c '$launch_cmd'"

    local ctx_note=""
    [[ -n "$kube_ctx" ]] && ctx_note+=" [k8s:$kube_ctx]"
    [[ -n "$aws_prof" ]] && ctx_note+=" [aws:$aws_prof]"
    _log_audit "new" "$target_dir" "$ctx_note"
    echo "Opened: $project$ctx_note"
}

cmd_kill() {
    local win="${1:-}"
    if [[ -z "$win" ]]; then
        printf "Kill window number: "; read -r win
    fi
    [[ "$win" =~ ^[0-9]+$ ]] || { echo "Invalid window number: $win" >&2; return 1; }

    local claude_pid
    claude_pid=$(_window_claude_pid "$win" 2>/dev/null) || true

    if [[ -n "$claude_pid" ]]; then
        printf "Sending SIGTERM to Claude PID %s ..." "$claude_pid"
        _safe_kill_claude "$claude_pid"
        echo " done."
    fi

    tmux kill-window -t "${CSM_SESSION}:${win}" 2>/dev/null || true
    _log_audit "kill" "window=$win" "pid=${claude_pid:-unknown}"
    echo "Killed window $win"
}

cmd_list() {
    printf "${BOLD}%-8s  %-8s  %-5s  %-30s  %s${RESET}\n" "PID" "STATUS" "AGE" "PROJECT" "CWD"
    printf '%0.s─' {1..80}; echo
    while IFS=$'\t' read -r pid alive st cwd project age_min; do
        local dead_marker=""
        [[ "$alive" != "True" ]] && dead_marker="  ${GREY}[dead]${RESET}"
        printf "%-8s  %-8s  %-5s  %-30s  %s%b\n" \
            "$pid" "$st" "${age_min}m" "${project:0:29}" "${cwd}" "$dead_marker"
    done < <(_get_sessions)
}

cmd_log() {
    local win="${1:-}"
    [[ -z "$win" ]] && { printf "Window number: "; read -r win; }
    python3 "$CSM_LIB_DIR/csm-status.py" log "$win"
}

cmd_jump() {
    local query="${1:-}"
    [[ -z "$query" ]] && { printf "Session name or number: "; read -r query; }

    if [[ "$query" =~ ^[0-9]+$ ]]; then
        tmux select-window -t "${CSM_SESSION}:${query}" 2>/dev/null || echo "No window $query"
        return
    fi

    local win
    win=$(tmux list-windows -t "$CSM_SESSION" -F '#{window_index} #{window_name}' 2>/dev/null \
        | grep -i "$query" | head -1 | awk '{print $1}') || true

    if [[ -n "$win" ]]; then
        tmux select-window -t "${CSM_SESSION}:${win}"
    else
        echo "No session matching '$query'"
    fi
}

cmd_adopt() {
    echo "Scanning for orphan Claude sessions (running outside CSM)..."
    local found=0 adopted=0

    while IFS=$'\t' read -r pid alive st cwd project age_min; do
        [[ "$alive" != "True" ]] && continue

        # Check if this PID is already a child of any CSM tmux pane
        local managed=false
        if tmux has-session -t "$CSM_SESSION" 2>/dev/null; then
            while IFS= read -r pane_pid; do
                local child_pid
                child_pid=$(pgrep -P "$pane_pid" -f "claude" 2>/dev/null | head -1 || true)
                if [[ "$child_pid" == "$pid" ]]; then
                    managed=true; break
                fi
            done < <(tmux list-panes -t "$CSM_SESSION" -a -F '#{pane_pid}' 2>/dev/null)
        fi

        if [[ "$managed" == "false" ]]; then
            (( found++ ))
            printf "  Found orphan: PID %-8s  %-20s  %s\n" "$pid" "$project" "$cwd"
            printf "  Kill & relaunch under CSM? [y/N]: "
            local ans; read -r ans
            if [[ "$ans" =~ ^[Yy]$ ]]; then
                _safe_kill_claude "$pid"
                sleep 0.3
                cmd_new "$cwd"
                (( adopted++ ))
            fi
        fi
    done < <(_get_sessions)

    if (( found == 0 )); then
        echo "  No orphans found — all Claude sessions are managed by CSM."
    else
        echo "  Adopted $adopted of $found orphan(s)."
    fi
}

cmd_doctor() {
    printf "${BOLD}=== CSM Doctor ===${RESET}\n\n"

    printf "  ${BOLD}Required:${RESET}\n"
    for dep in tmux python3 zsh; do
        if command -v "$dep" &>/dev/null; then
            printf "  %-14s ${GREEN}✓${RESET} %s\n" "$dep" "$(command -v "$dep")"
        else
            printf "  %-14s ${RED}✗ NOT FOUND${RESET}\n" "$dep"
        fi
    done

    printf "\n  ${BOLD}Optional (improves experience):${RESET}\n"
    printf "  %-14s %s\n" "fzf" "better directory picker (apt install fzf)"
    printf "  %-14s %s\n" "inotifywait" "real-time updates (apt install inotify-tools)"
    printf "  %-14s %s\n" "notify-send" "desktop notifications (apt install libnotify-bin)"
    for dep in fzf inotifywait notify-send; do
        if command -v "$dep" &>/dev/null; then
            printf "  %-14s ${GREEN}✓${RESET} installed\n" "$dep"
        else
            printf "  %-14s ${GREY}-${RESET} not installed\n" "$dep"
        fi
    done

    printf "\n  ${BOLD}Claude sessions:${RESET}\n"
    local live=0 dead=0
    while IFS=$'\t' read -r _ alive _; do
        [[ "$alive" == "True" ]] && (( live++ )) || (( dead++ ))
    done < <(_get_sessions)
    printf "  Live: %d   Dead: %d\n" "$live" "$dead"

    printf "\n  ${BOLD}CSM tmux session:${RESET}\n"
    if tmux has-session -t "$CSM_SESSION" 2>/dev/null; then
        local nwin; nwin=$(tmux list-windows -t "$CSM_SESSION" 2>/dev/null | wc -l)
        printf "  ${GREEN}Running${RESET} (%d windows)\n" "$nwin"
    else
        printf "  ${GREY}Not running${RESET}\n"
    fi

    printf "\n  ${BOLD}Paths:${RESET}\n"
    printf "  Lib dir:   %s\n" "$CSM_LIB_DIR"
    printf "  State dir: %s\n" "$CSM_STATE_DIR"
    printf "  Audit log: %s\n" "$CSM_AUDIT_LOG"

    printf "\n  ${BOLD}Schema check:${RESET}\n"
    python3 "$CSM_LIB_DIR/csm-status.py" schema-check 2>/dev/null || \
        echo "  Could not run schema check."
}

cmd_help() {
    cat <<'EOF'
csm — Claude Session Manager

USAGE:
  csm                  Launch or attach to the CSM dashboard
  csm new [DIR]        Open new Claude session in DIR (default: interactive pick)
  csm kill [WIN]       Gracefully kill session by window number
  csm list             List all Claude sessions
  csm log [WIN]        Tail the transcript for a session
  csm jump [NAME]      Switch to session by name or number
  csm adopt            Detect and re-manage orphan Claude sessions
  csm doctor           Check dependencies and session health
  csm help             Show this help

DASHBOARD KEYS:
  1-9    Switch to window       N   New session
  J      Jump by name           K   Kill session (graceful)
  L      Log tail (popup)       A   Adopt orphans
  R      Force refresh          Q   Quit (detach from tmux)

PER-PROJECT CONFIG (.csmrc in repo root):
  kube_context=cgk8s-dev-cluster
  aws_profile=hyp-creditguard

OPTIONAL DEPENDENCIES:
  fzf              Better directory picker  (apt install fzf)
  inotify-tools    Real-time updates        (apt install inotify-tools)
  libnotify-bin    Desktop notifications    (apt install libnotify-bin)
EOF
}

# ── Dispatch ──────────────────────────────────────────────────────────────────

main() {
    case "${1:-}" in
        new)          shift; cmd_new "$@" ;;
        kill|rm)      shift; cmd_kill "$@" ;;
        list|ls)      cmd_list ;;
        log)          shift; cmd_log "$@" ;;
        jump)         shift; cmd_jump "$@" ;;
        adopt)        cmd_adopt ;;
        doctor)       cmd_doctor ;;
        install)      bash "$(dirname "${BASH_SOURCE[0]}")/install.sh" ;;
        help|-h|--help) cmd_help ;;
        _dashboard)   _dashboard_loop ;;
        "")           cmd_attach ;;
        *)            echo "Unknown command: $1"; echo; cmd_help; exit 1 ;;
    esac
}

main "$@"
